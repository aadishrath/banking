{
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/angular-banking/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://banking-jmkt.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
